# Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Modelo padrao (haiku = barato, sonnet = inteligente)
AI_MODEL=claude-haiku-4-5-20251001

# Seu nome (para o bot saber quem voce e)
MY_NAME=Maikeo

# Modo de resposta: auto (responde sozinho) | suggest (sugere e espera aprovacao) | summary (so resume)
BOT_MODE=suggest

# Contatos que o bot NUNCA responde automaticamente (separados por virgula)
BLACKLIST_CONTACTS=

# Contatos VIP que sempre recebem resposta rapida
VIP_CONTACTS=

# Horario de resumo diario (formato HH:MM)
SUMMARY_TIME=22:00

# Maximo de tokens por resposta
MAX_TOKENS_PER_RESPONSE=500

# Idioma padrao
LANGUAGE=pt-BR
