# ============================================================
# MSM_Pro — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env
# ============================================================

# --- Banco de Dados ---
DATABASE_URL=postgresql+asyncpg://msm:msm@localhost:5432/msm_pro

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
SECRET_KEY=troque-por-uma-chave-secreta-forte-de-pelo-menos-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Email (alertas) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Mercado Livre OAuth ---
ML_CLIENT_ID=seu-app-id-do-mercado-livre
ML_CLIENT_SECRET=seu-client-secret-do-mercado-livre
ML_REDIRECT_URI=http://localhost:8000/api/v1/auth/ml/callback

# --- App ---
ENVIRONMENT=development
DEBUG=true
FRONTEND_URL=http://localhost:5173
