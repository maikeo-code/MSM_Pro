# ============================================================
# MSM_Pro — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env
# ============================================================

# --- Banco de Dados ---
DATABASE_URL=postgresql+asyncpg://msm:msm@localhost:5432/msm_pro

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
SECRET_KEY=troque-por-uma-chave-secreta-forte-de-pelo-menos-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Email (alertas + Daily Intel Report) ---
# Gmail: ative "Verificacao em 2 etapas" e gere uma App Password em:
# https://myaccount.google.com/apppasswords
# SMTP_PASS deve ser a App Password de 16 caracteres (ex: "abcd efgh ijkl mnop")
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
# Remetente exibido no email (opcional — usa SMTP_USER se omitido)
SMTP_FROM=MSM_Pro <seu-email@gmail.com>
# Destinatario padrao do Daily Intel Report
SMTP_TO=maikeo@msmrp.com

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Mercado Livre OAuth ---
ML_CLIENT_ID=seu-app-id-do-mercado-livre
ML_CLIENT_SECRET=seu-client-secret-do-mercado-livre
ML_REDIRECT_URI=http://localhost:8000/api/v1/auth/ml/callback

# --- Token Encryption (Fernet) ---
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Se não definido, será derivado do SECRET_KEY automaticamente
TOKEN_ENCRYPTION_KEY=

# --- Anthropic (Consultor IA) ---
ANTHROPIC_API_KEY=

# --- App ---
ENVIRONMENT=development
DEBUG=true
FRONTEND_URL=http://localhost:5173
