            "text": "{\"initial_data\":{\"id\":\"item_funnel_module\",\"ui_type\":\"item_funnel_module\",\"data\":{\"class_names\":[\"sales-funnel-section\"]},\"bricks\":[{\"id\":\"item_funnel_header\",\"ui_type\":\"item_funnel_header\",\"data\":{\"class_names\":[\"sales-funnel-header\"]},\"bricks\":[{\"id\":\"item_funnel_section_title\",\"ui_type\":\"item_funnel_section_title\",\"data\":{\"text\":\"Conversión de visitas\",\"type\":\"body\",\"size\":\"m\",\"component\":\"h2\",\"weight\":\"semibold\"}}]},{\"id\":\"item_funnel_content\",\"ui_type\":\"item_funnel_content\",\"bricks\":[{\"id\":\"item_funnel_message\",\"ui_type\":\"item_funnel_message\",\"data\":{\"class_name\":\"sc-item-funnel-message\",\"hierarchy\":\"quiet\",\"body\":\"Os dados de \\\"Intenção de compra\\\" não estão disponíveis por variação. É possível acessar essa informação ao analisar todas as variações.\"}},{\"id\":\"item_funnel_chart\",\"ui_type\":\"metrics_funnel_chart\",\"data\":{\"skeleton\":false,\"dataset\":[{\"stage\":\"unique_visits\",\"all_sales\":96},{\"stage\":\"gross_sales\",\"all_sales\":6}],\"total_conversion\":{\"id\":\"total_conversion\",\"label\":\"Conversión total\",\"value\":\"6,3%\",\"size\":\"small\",\"hierarchy\":\"quiet\",\"tooltip\":{\"size\":\"small\",\"content\":\"Porcentagem de visitas únicas que foram convertidas em uma compra.\",\"side\":\"right\"},\"pill\":{\"value\":\"3,0 puntos\",\"state\":\"up\",\"type\":\"green\",\"hierarchy\":\"quiet\",\"tooltip\":{\"size\":\"small\",\"content\":\"Comparado ao período anterior: 11 mar. 2026\",\"number\":\"3,3%\",\"side\":\"bottomLeft\"}}},\"tooltip_labels\":{\"title\":\"Conversão\",\"from\":\"De\",\"to\":\"a\"},\"series_config\":[{\"id\":\"all_sales\",\"label\":\"Todas as suas vendas\",\"gradients\":[\"andes-secondary-palette-d-100\",\"andes-secondary-palette-d-500\"]}],\"stage_config\":[{\"id\":\"unique_visits\",\"display_name\":\"Visitas únicas\",\"tooltip\":{\"size\":\"small\",\"content\":\"Quantidade de usuários únicos que acessaram o anúncio.\"},\"pills\":[{\"id\":\"all_sales\",\"value\":\"6,3%\",\"size\":\"small\",\"hierarchy\":\"quiet\",\"tooltip\":{\"size\":\"small\"}}],\"legends\":[{\"id\":\"all_sales\",\"primary\":\"96\",\"secondary\":\" \"}]},{\"id\":\"gross_sales\",\"display_name\":\"Vendas brutas\",\"tooltip\":{\"size\":\"small\",\"content\":\"Quantidade de vendas realizadas e valor total gerado, sem considerar tarifas, cancelamentos ou devoluções.\"},\"pills\":[{\"id\":\"all_sales\",\"value\":\"6,3%\",\"size\":\"small\",\"hierarchy\":\"quiet\",\"tooltip\":{\"size\":\"small\",\"side\":\"bottom\"}}],\"legends\":[{\"id\":\"all_sales\",\"primary\":\"6\",\"secondary\":\"(R$ 1.743)\"}]}]}}]}]},\"status\":\"success\"}"
